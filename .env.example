# ============================================================
# LLM 多模型配置
# ============================================================
# 默认模型（通用任务）
LLM_DEFAULT_MODEL=deepseek-chat
LLM_DEFAULT_BASE_URL=https://api.deepseek.com
LLM_DEFAULT_API_KEY=your_deepseek_api_key_here

# 推理模型（复杂推理任务，可选）
LLM_REASONER_MODEL=deepseek-reasoner
LLM_REASONER_BASE_URL=https://api.deepseek.com
LLM_REASONER_API_KEY=your_deepseek_api_key_here

# LLM-as-Judge 异构裁判（评测用，可选）
# 与生成模型不同厂商，消除 self-preference bias（自偏好偏差）
# 复用 DashScope key 即可
LLM_JUDGE_MODEL=qwen-plus
LLM_JUDGE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_JUDGE_API_KEY=your_dashscope_api_key_here

# RAGAS 评测裁判（ragas_eval.py 读取，可选，建议与 LLM_JUDGE 保持一致）
EVAL_LLM_MODEL=qwen-plus
EVAL_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EVAL_LLM_API_KEY=your_dashscope_api_key_here

# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com

# ============================================================
# PostgreSQL + pgvector
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_fitness
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=fitness_assistant

# ============================================================
# Neo4j 图数据库
# ============================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ============================================================
# Redis 缓存
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6380

# ============================================================
# MinIO 对象存储
# ============================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
